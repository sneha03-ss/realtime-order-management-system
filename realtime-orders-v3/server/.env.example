# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ordersdb
DB_USER=postgres
DB_PASSWORD=postgres

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Email (Gmail SMTP) ────────────────────────────────────────
# The Gmail account that SENDS all order notification emails.
# Emails are delivered to each order's own customer_email address.
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your account password).
# Generate at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification enabled on your Google account.)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# NOTIFICATION_RECEIVER has been removed.
# Each email is now sent to the customer's own email address stored on the order.
